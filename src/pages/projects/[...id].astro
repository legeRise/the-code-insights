---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({ params: { id: project.id }, props: { project } }));
}
const { project } = Astro.props;
const { Content } = await render(project);
const base = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/`;
const assetUrl = (path: string) => path.startsWith('/') ? `${base}${path.slice(1)}` : path;
---
<BaseLayout title={project.data.title} description={project.data.description}>
  <article class="narrow">
    <header class="article-head"><p class="eyebrow">Project</p><h1>{project.data.title}</h1><p class="lede">{project.data.description}</p>{project.data.image && <img src={assetUrl(project.data.image)} alt="" />}<div class="project-links">{project.data.url && <a href={project.data.url}>Visit project →</a>}{project.data.repository && <a href={project.data.repository}>Source code →</a>}</div></header>
    <div class="prose"><Content /></div>
  </article>
</BaseLayout>
