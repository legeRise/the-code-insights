---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
const projects = (await getCollection('projects')).sort((a, b) => b.data.order - a.data.order);
const base = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/`;
const assetUrl = (path: string) => path.startsWith('/') ? `${base}${path.slice(1)}` : path;
---
<BaseLayout title="Projects" description="Things designed and built by The Code Insight.">
  <div class="narrow"><p class="eyebrow">Things I build</p><h1>Projects</h1><p class="lede">A record of things I have built over time, public or private.</p></div>
  <div class="cards">{projects.map(({ id, data }) => <article class="card">{data.image && <img src={assetUrl(data.image)} alt="" />}<h2><a href={`${base}projects/${id}`}>{data.title}</a></h2><p>{data.description}</p></article>)}</div>
</BaseLayout>
