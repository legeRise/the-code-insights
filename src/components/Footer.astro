---
const today = new Date();
---

<footer>
	&copy; {today.getFullYear()} The Code Insights. All rights reserved.
	<p class="tagline">A blog about coding, development, and the lessons learned along the way.</p>
	<div class="footer-links">
		<a href="/">Home</a>
		<a href="/projects">Projects</a>
		<a href="/blog">Blog</a>
		<a href="/about">About</a>
	</div>
</footer>
<style>
	footer {
		padding: 2em 1em 6em 1em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
	}
	.tagline {
		font-size: 0.9em;
		margin: 0.5em 0;
	}
	.footer-links {
		display: flex;
		justify-content: center;
		gap: 1em;
		margin-top: 1em;
	}
	.footer-links a {
		text-decoration: none;
		color: rgb(var(--gray));
	}
	.footer-links a:hover {
		color: rgb(var(--gray-dark));
	}
</style>
